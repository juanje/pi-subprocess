{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "preset": "none" }
  },
  "files": {
    "includes": ["**", "!**/node_modules", "!**/dist", "!**/package-lock.json"]
  }
}
