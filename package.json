{
  "name": "pi-subprocess",
  "version": "0.2.0",
  "description": "Minimal subprocess isolation for Pi agents. Spawns isolated Pi subprocesses and returns curated results.",
  "type": "module",
  "license": "MIT",
  "author": "Juanje Ojeda",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juanje/pi-subprocess.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "subprocess",
    "subagent",
    "context-isolation"
  ],
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "check": "tsc --noEmit && biome check . && vitest run"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "typescript": "^5.0.0",
    "vitest": "^3.2.0"
  }
}
